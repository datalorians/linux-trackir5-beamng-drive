#!/usr/bin/env bash
set -euo pipefail

pid_file="$HOME/.local/state/beamng-trackir-spacemouse/adapter.pid"

if [[ -f "$pid_file" ]]; then
  pid="$(<"$pid_file")"
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid"
    for _ in {1..30}; do
      kill -0 "$pid" 2>/dev/null || break
      sleep 0.1
    done
  fi
  rm -f "$pid_file"
fi

rm -f /tmp/beamng_trackir_center /tmp/beamng_trackir_pause
rm -f /tmp/linuxtrack_npclient_center /tmp/linuxtrack_npclient_pause
