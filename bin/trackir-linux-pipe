#!/usr/bin/env bash
set -euo pipefail

prefix="${LINUXTRACK_PREFIX:-$HOME/.local/opt/linuxtrack-trackir}"
export LD_LIBRARY_PATH="$prefix/lib/linuxtrack${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export PATH="$prefix/bin:$PATH"

exec "$prefix/bin/ltr_pipe" --output-stdout --format-default --ltr-timeout="${LTR_TIMEOUT:-12}" "$@"
