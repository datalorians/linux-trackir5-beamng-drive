+static void update_bridge_pause_led()
+{
+  static bool initialized = false;
+  static bool last_paused = false;
+  typedef bool (*set_status_led_fun)(bool running);
+  static set_status_led_fun set_status_led = NULL;
+  static bool looked_up = false;
+  bool paused = access(NPCLIENT_PAUSE_FLAG, F_OK) == 0;
+
+  if(!looked_up){
+    set_status_led = (set_status_led_fun)dlsym(RTLD_DEFAULT, "ltr_int_set_status_led_tir");
+    if(set_status_led == NULL){
+      ltr_int_log_message("NPClient bridge pause LED: TrackIR LED symbol unavailable.\n");
+    }
+    looked_up = true;
+  }
+
+  if(!initialized || (paused != last_paused)){
+    ltr_int_log_message("NPClient bridge pause LED: %s\n", paused ? "paused" : "running");
+    if(set_status_led != NULL){
+      set_status_led(!paused);
+    }
+    initialized = true;
+    last_paused = paused;
+  }
+}
